    {
      "name": "Rate Limiting",
      "item": [
        {
          "name": "Trigger Rate Limit (429)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Run this request 101 times using Postman Collection Runner",
                  "// with iteration count set to 101 to trigger the 429 rate limit.",
                  "// Window: 15 minutes, Max: 100 requests."
                ],
                "type": "text/javascript"
              }
